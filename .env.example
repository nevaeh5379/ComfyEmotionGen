# Copy to .env and adjust. Used by docker-compose.

# Where the ComfyUI server(s) live, as seen from inside the backend container.
# Docker Desktop (Win/Mac): host.docker.internal points to your host machine.
# Linux: replace with the host's LAN IP, or run ComfyUI in a sibling container.
# Multiple GPUs: comma-separate URLs.
COMFYUI_WORKERS=http://host.docker.internal:8188

# Where the *browser* reaches the backend. If you publish backend on a non-default
# port, change BACKEND_PORT below and update this URL to match.
BACKEND_URL=http://localhost:8000

# Published ports on the host.
BACKEND_PORT=8000
FRONTEND_PORT=8080

# Build-time version metadata (CI sets these; leave blank for local builds).
CEG_BUNDLE_VERSION=
CEG_COMMIT=
